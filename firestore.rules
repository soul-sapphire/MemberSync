rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions for common checks
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }
    
    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function matchesOrg(orgId) {
      return isAuthenticated() && getUserData().organizationId == orgId;
    }

    // 1. Users Collection
    match /users/{userId} {
      // Users can read their own profile
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // Prevent users from setting their own role to admin or changing org during creation
      allow create: if isAuthenticated() && request.auth.uid == userId && 
                    request.resource.data.role != 'admin';
      
      // CRITICAL: Prevent role escalation or organization hopping
      allow update: if isAuthenticated() && (
        (request.auth.uid == userId && 
         request.resource.data.role == resource.data.role && 
         request.resource.data.organizationId == resource.data.organizationId) ||
        isAdmin()
      );
      
      allow delete: if isAdmin();
    }

    // 2. Members Collection
    match /members/{memberId} {
      // Enforce Organization Isolation for reading
      allow read: if isAuthenticated() && (
        (resource.data.uid == request.auth.uid) || 
        (matchesOrg(resource.data.organizationId) && (isAdmin() || hasRole('manager') || hasRole('staff')))
      );
      
      // Enforce Organization Isolation for creation
      allow create: if isAuthenticated() && 
                    request.resource.data.uid == request.auth.uid &&
                    matchesOrg(request.resource.data.organizationId);
      
      // Enforce Organization Isolation for updates
      allow update: if isAuthenticated() && (
        (resource.data.uid == request.auth.uid && 
         request.resource.data.status == resource.data.status && 
         request.resource.data.organizationId == resource.data.organizationId) ||
        (matchesOrg(resource.data.organizationId) && (isAdmin() || hasRole('manager')))
      );
      
      allow delete: if isAdmin() && matchesOrg(resource.data.organizationId);
    }

    // 3. Admin-Only Collections
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Immutable, written by system only
    }

    match /analytics_daily/{aggId} {
      allow read: if isAdmin() && matchesOrg(resource.data.organizationId);
      allow write: if false; // Generated by system
    }

    // 4. Moderation/Staff Collections
    match /violations/{violationId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        (matchesOrg(resource.data.organizationId) && (isAdmin() || hasRole('manager') || hasRole('staff')))
      );
      allow write: if isAuthenticated() && matchesOrg(request.resource.data.organizationId) && 
                   (isAdmin() || hasRole('manager') || hasRole('staff'));
    }

    // 5. Standard collections (Payments, Attendance, Notifications)
    match /{collection}/{docId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        (matchesOrg(resource.data.organizationId) && (isAdmin() || hasRole('manager') || hasRole('staff')))
      );
      
      allow create, update: if isAuthenticated() && 
                            matchesOrg(request.resource.data.organizationId) && 
                            (isAdmin() || hasRole('manager') || hasRole('staff'));
      
      allow delete: if isAdmin() && matchesOrg(resource.data.organizationId);
    }
  }
}
